        round(avg(trip_duration_minutes)::numeric, 2) as avg_duration_mins,
        round(avg(surge_multiplier)::numeric, 2) as avg_surge
    from trips
    group by pickup_zone
)
select * from aggregated
order by total_revenue desc
  );
  
